{
  "name": "dsmt-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow bun",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "link": "cd apps/cli && bun link"
