{
  "name": "dsmt-monorepo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "preinstall": "npx only-allow bun",
    "dev": "turbo dev",
    "build": "turbo run build",
    "lint": "turbo lint",
    "format": "turbo format",
    "typecheck": "turbo typecheck",
    "link": "cd apps/cli && bun link",
    "unlink": "cd apps/cli && bun unlink"
  },
  "devDependencies": {
    "prettier": "3.8.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "turbo": "^2.4.4",
    "typescript": "^5.8.3"
  }
}
